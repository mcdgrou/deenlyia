# Supabase Configuration
# Public URL for client-side
VITE_SUPABASE_URL=https://your-project.supabase.co
# Public Anon Key for client-side
VITE_SUPABASE_ANON_KEY=your-anon-key
# Service Role Key for server-side (DO NOT prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration
# Secret key for server-side (DO NOT prefix with VITE_)
STRIPE_SECRET_KEY=
# Webhook secret for server-side (DO NOT prefix with VITE_)
STRIPE_WEBHOOK_SECRET=
# Publishable key for client-side (MUST prefix with VITE_)
VITE_STRIPE_PUBLISHABLE_KEY=
# Price ID for client-side (MUST prefix with VITE_)
VITE_STRIPE_PRICE_ID_PREMIUM=

# Gemini API Configuration
# API Key for server-side (DO NOT prefix with VITE_)
GEMINI_API_KEY=
